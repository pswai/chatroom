# AI Provider: 'stub' (default) | 'anthropic' | 'google'
AI_PROVIDER=stub

# Anthropic API Key (required when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Google AI API Key (required when AI_PROVIDER=google)
GOOGLE_AI_API_KEY=

# Neon Postgres (optional — app works fully in-memory without this)
DATABASE_URL=

# Public URL for share links
PUBLIC_SITE_URL=http://localhost:3000
